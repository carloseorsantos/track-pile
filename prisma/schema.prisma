generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer, -pooler host) — used at runtime
  directUrl = env("DATABASE_URL_UNPOOLED") // direct connection — used for `prisma db push`/migrations
}

/* ---------- Auth.js (NextAuth) models ---------- */
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  language      String    @default("pt-BR")

  accounts Account[]
  sessions Session[]
  jobs     Job[]

  // Settings (from the design's toggles)
  weeklyDigest    Boolean @default(true)
  interviewEmails Boolean @default(false)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

/* ---------- Product models ---------- */
enum Plan {
  FREE
  PRO
}

model Job {
  id             String    @id @default(cuid())
  userId         String
  company        String
  role           String
  status         String    @default("Salvo")
  link           String?
  source         String    @default("LinkedIn")
  appliedAt      DateTime?
  nextDate       DateTime?
  salary         String?
  salaryCurrency String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  history StatusHistory[]

  @@index([userId])
}

/// Audit trail of status changes — foundation for future metrics
/// (time-to-interview, conversion rates between stages).
model StatusHistory {
  id        String   @id @default(cuid())
  jobId     String
  from      String?
  to        String
  changedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}
