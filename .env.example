# PostgreSQL connection string (Neon / Supabase / local)
# Pooled connection (PgBouncer, "-pooler" host) — used at runtime by Prisma Client.
# Note the required `pgbouncer=true` param, or serverless functions can hit
# "prepared statement already exists" errors under concurrent load.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/trackpile?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct (unpooled) connection — used only for `prisma db push` / migrations.
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.aws.neon.tech/trackpile?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET="your-generated-secret"

# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client ID)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# For production, also set:
# AUTH_URL="https://your-domain.com"
